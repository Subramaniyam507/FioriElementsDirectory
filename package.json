{
  "name": "FioriElementsDirectory",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "@cap-js/cds-types": "^0.16.0",
    "@types/node": "^24.0.0",
    "tsx": "^4",
    "typescript": "^6.0.0",
    "@cap-js/cds-typer": ">=0.1",
    "cds-plugin-ui5": "^0.17.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.49"
  },
  "scripts": {
    "start": "cds-serve",
    "typecheck": "tsc --noEmit -p tsconfig.cdsbuild.json",
    "build:service": "tsc -p tsconfig.cdsbuild.json",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "watch-listreport-objectpage": "cds watch --open com.subbu.listreportobjectpage/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy FioriElementsDirectory --delete-services --delete-service-keys --delete-service-brokers",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "destinations": true
    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/listreport-objectpage"
  ]
}
