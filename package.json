{
  "name": "FioriElementsDirectory",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "@cap-js/cds-types": "^0.16.0",
    "@types/node": "^24.0.0",
    "tsx": "^4",
    "typescript": "^6.0.0",
    "@cap-js/cds-typer": ">=0.1"
  },
  "scripts": {
    "start": "cds-serve",
    "typecheck": "tsc --noEmit -p tsconfig.cdsbuild.json",
    "build:service": "tsc -p tsconfig.cdsbuild.json",
    "build": "npm run typecheck && npx cds build --production && npm run build:service"

  },
  "private": true,
  "cds": {
    "requires": {
      "destinations": true
    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}
